# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/interview_platform

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server Configuration
DEBUG=False

# Anyone registering with this code (matched exactly) becomes an interviewer.
# Leave blank to disable self-service interviewer signups entirely.
INTERVIEWER_INVITE_CODE=

# Comma-separated list of frontend origins allowed to call this API (CORS).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
